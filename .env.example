APP_NAME="FreeV2Ray Bot"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Public URL of the web panel / webhook host (used to build /admin links).
APP_URL=https://bot.example.com

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

# Domain FrankenPHP serves (enables automatic HTTPS). Use localhost for local.
SERVER_NAME=bot.example.com

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# ---------------------------------------------------------------------------
# Database (MySQL via docker-compose)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=freev2ray
DB_USERNAME=freev2ray
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ---------------------------------------------------------------------------
# Cache / queue / session — Redis (predis, no PHP extension required)
# ---------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Telegram bot
# ---------------------------------------------------------------------------
TELEGRAM_TOKEN=123456:your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
# Comma-separated Telegram numeric ids that get admin access in the bot.
TELEGRAM_ADMIN_IDS=
# Secret segment in the webhook path: /webhook/{secret}
TELEGRAM_WEBHOOK_SECRET=change-this-long-random-string
# Nutgram log channel (set to "stack" to enable bot request logging).
TELEGRAM_LOG_CHANNEL=null

# ---------------------------------------------------------------------------
# Default config issuance (used until you create Plans in the panel)
# ---------------------------------------------------------------------------
DEFAULT_DATA_GB=10
DEFAULT_DURATION_DAYS=30
MAX_ACTIVE_CONFIGS_PER_USER=1
CONFIG_IDENTIFIER_PREFIX=fv

# ---------------------------------------------------------------------------
# First web/Filament admin (seeded once)
# ---------------------------------------------------------------------------
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

MAIL_MAILER=log
